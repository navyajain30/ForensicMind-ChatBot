# Environment Variables — copy this file to .env and fill in your values

# LLM Provider — Groq API (free tier, fast inference)
# Get your key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Ollama local server (used for embeddings)
OLLAMA_BASE_URL=http://localhost:11434

# Embedding model (must be pulled via: ollama pull nomic-embed-text)
EMBEDDING_MODEL=nomic-embed-text

# Vision / multimodal model
VISION_MODEL=llava

# LLM model name (tinyllama is lightweight; use llama3 for better quality)
LLM_MODEL=tinyllama
